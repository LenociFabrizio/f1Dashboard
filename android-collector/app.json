{
  "expo": {
    "name": "F1 Telemetry Relay",
    "slug": "f1-telemetry-collector",
    "owner": "ziofabri",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0b0b0f",
    "assetBundlePatterns": ["**/*"],
    "android": {
      "package": "com.f1league.telemetryrelay",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_DATA_SYNC",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-dev-client",
      "./plugins/withForegroundServiceType"
    ],
    "extra": {
      "eas": {
        "projectId": "240adfa0-d0b0-418e-9ba7-0d01b0456d4b"
      }
    }
  }
}
