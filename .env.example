# ============================================================
#  F1 Championship Portal - Configurazione ambiente
#  Copia questo file in ".env" e personalizza i valori.
# ============================================================

# Porta del server (solo esecuzione locale)
PORT=3000

# Ambiente: development | production
NODE_ENV=development

# Segreto per la firma dei JWT (CAMBIALO in produzione!)
JWT_SECRET=cambiami-con-una-stringa-lunga-e-casuale
JWT_EXPIRES_IN=7d

# --- Database (libSQL / Turso) ---
# Locale: file SQLite embedded (default). Produzione: URL Turso libsql://...
DATABASE_URL=file:server/database/f1.db
# In produzione:
# DATABASE_URL=libsql://il-tuo-db.turso.io
DATABASE_AUTH_TOKEN=

# --- Upload immagini (Vercel Blob) ---
# Locale: lascia vuoto (i file vanno in public/uploads).
# Produzione: token del Blob store Vercel.
BLOB_READ_WRITE_TOKEN=

# URL base del frontend (opzionale; su Vercel same-origin)
CLIENT_URL=http://localhost:3000

# --- Predisposizione OAuth reale (non usati nel mock) ---
PSN_CLIENT_ID=
PSN_CLIENT_SECRET=
EA_CLIENT_ID=
EA_CLIENT_SECRET=
